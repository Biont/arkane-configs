#!/usr/bin/env bash


function run_cmd() {
 echo "$PWD"
 readarray -td ' ' CMD <<<"${1}"
 "${CMD[@]%$'\n'}"
}

function wait-online() {
 tries=600

 for i in $(seq $tries); do
  if nc -z 127.0.0.1 $1 > /dev/null ; then
    # Ready
   echo "Port ${1} online"
    exit 0
  fi
  /bin/sleep 0.1
 done
 echo "Port ${1} failed to come online after ${tries} attempts" >&2
 exit 1
}

function start() {
 cd "${WORKING_DIRECTORY}"
 run_cmd "${EXEC_START}"
}

function stop() {
 cd "${WORKING_DIRECTORY}"
 run_cmd "${EXEC_STOP}"
}

case "$1" in
start | stop | wait-online)
  "$@"
  exit
  ;;
esac
